{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vocal-assistant",
  "version": "0.1.0",
  "identifier": "com.handicap.vocal",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Assistant Vocal",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' data: filesystem: ws: wss: http: https: tauri:; img-src 'self' data:; media-src 'self' asset:;",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$DATA/**", "$DOCUMENT/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Assistant vocal",
    "longDescription": "Application de reconnaissance vocale"
  }
}
